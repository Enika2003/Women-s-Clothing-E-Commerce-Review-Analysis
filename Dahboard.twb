      <column caption='Recommendation Rate %' datatype='real' name='[Calculation_0248819766837251]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Recommended IND]) * 100' />
      </column>
      <column caption='Negative Review Rate %' datatype='real' name='[Calculation_0248819767369732]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Rating] &lt;= 2 THEN 1 ELSE 0 END) / COUNT([Rating]) * 100' />
      </column>
      <column caption='Sentiment Color' datatype='string' name='[Calculation_0248819767439365]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sentiment] = &quot;Positive&quot; THEN &quot;Positive&quot;&#10;ELSEIF [Sentiment] = &quot;Neutral&quot; THEN &quot;Neutral&quot;&#10;ELSE &quot;Negative&quot;&#10;END' />
      </column>
      <column caption='Review Count' datatype='integer' name='[Calculation_0248819767549958]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Rating])' />
      </column>
      <column caption='Avg Helpful Votes' datatype='real' name='[Calculation_0248819767869447]' role='measure' type='quantitative'>
